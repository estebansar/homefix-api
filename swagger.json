{
  "swagger": "2.0",
  "info": {
    "title": "HomeFix API",
    "description": "API documentation for the HomeFix final project",
    "version": "1.0.0"
  },
  "host": "homefix-api-2yn3.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/homes": {
      "get": {
        "summary": "Get all homes",
        "description": "Returns all homes saved in HomeFix",
        "responses": {
          "200": {
            "description": "Homes returned success"
          }
        }
      },
      "post": {
        "summary": "Create a home",
        "description": "Adds a new home",
        "parameters": [
          {
            "in": "body",
            "name": "home",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Home"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Home created success"
          },
          "400": {
            "description": "Missing required info"
          }
        }
      }
    },
    "/homes/{id}": {
      "get": {
        "summary": "Get one home",
        "description": "Returns one home by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Home returned"
          },
          "400": {
            "description": "Invalid home id"
          }
        }
      },
      "put": {
        "summary": "Update a home",
        "description": "Updates one home by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "home",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Home"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Home updated success"
          },
          "400": {
            "description": "Invalid id or missing required info"
          }
        }
      },
      "delete": {
        "summary": "Delete a home",
        "description": "Deletes one home by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Home deleted success"
          },
          "400": {
            "description": "Invalid home id"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Get all users",
        "description": "Returns all users saved in HomeFix",
        "responses": {
          "200": {
            "description": "Users returned success"
          }
        }
      },
      "post": {
        "summary": "Create a user",
        "description": "Adds a new user",
        "parameters": [
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": {
              "$ref": "#/definitions/User"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User created success"
          },
          "400": {
            "description": "Missing required info"
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Get one user",
        "description": "Returns one user by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "User returned"
          },
          "400": {
            "description": "Invalid user id"
          }
        }
      },
      "put": {
        "summary": "Update a user",
        "description": "Updates one user by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": {
              "$ref": "#/definitions/User"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "User updated success"
          },
          "400": {
            "description": "Invalid id or missing required info"
          }
        }
      },
      "delete": {
        "summary": "Delete a user",
        "description": "Deletes one user by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "User deleted success"
          },
          "400": {
            "description": "Invalid user id"
          }
        }
      }
    }
  },
  "definitions": {
    "Home": {
      "type": "object",
      "required": [
        "homeName",
        "address",
        "city",
        "state",
        "zipCode",
        "homeType",
        "yearBuilt"
      ],
      "properties": {
        "homeName": {
          "type": "string",
          "example": "Main House"
        },
        "address": {
          "type": "string",
          "example": "123 Maple Street"
        },
        "city": {
          "type": "string",
          "example": "Eagle Mountain"
        },
        "state": {
          "type": "string",
          "example": "UT"
        },
        "zipCode": {
          "type": "string",
          "example": "84005"
        },
        "homeType": {
          "type": "string",
          "example": "Single Family"
        },
        "yearBuilt": {
          "type": "integer",
          "example": 2020
        }
      }
    },
    "User": {
      "type": "object",
      "required": ["firstName", "lastName", "email", "phone"],
      "properties": {
        "firstName": {
          "type": "string",
          "example": "John"
        },
        "lastName": {
          "type": "string",
          "example": "Smith"
        },
        "email": {
          "type": "string",
          "example": "johnsmith@email.com"
        },
        "phone": {
          "type": "string",
          "example": "801-555-1234"
        }
      }
    }
  }
}